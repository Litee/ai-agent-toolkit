{
  "description": "Detects whether the current session is running inside cmux and prints session context info",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/detect_cmux.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
