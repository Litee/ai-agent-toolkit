{
  "description": "Blocks direct editing of protected system files (AWS config, SSH keys, shell profiles, lockfiles)",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/protect-files.js",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
